# StudyOS Backend Environment Variables
# Copy this file to .env and adjust values for your local environment

# ── Application ──────────────────────────────────────────────
APP_NAME="StudyOS"
APP_VERSION="0.1.0"
DEBUG=False

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="sqlite:///./studyos.db"

# ── Vector Search ────────────────────────────────────────────
FAISS_INDEX_DIR="./data/faiss_indices"
EMBEDDING_MODEL="all-MiniLM-L6-v2"
EMBEDDING_DIMENSION=384

# ── Document Processing ──────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_UPLOAD_SIZE_MB=50

# ── RAG ──────────────────────────────────────────────────────
TOP_K_RESULTS=5

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list or JSON array of allowed origins
# CORS_ORIGINS='["http://localhost:3000"]'
